      margin-left: 0.25rem;
    }
    .footnote {
      font-size: 0.8rem;
      color: #64748b;
      margin-top: 0.5rem;
    }
    .footnote a {
      color: #38bdf8;
      text-decoration: none;
    }
    .footnote a:hover {
      text-decoration: underline;
    }
  </style>

  <div class="dashboard-header">
    <h1>bootc Active Devices & Adoption</h1>
