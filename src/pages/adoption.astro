      color: #94a3b8;
    }

    /* Visual Layout Blocks */
    .dashboard-panel {
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 20px;
      padding: 1.5rem;
      box-shadow: var(--site-shadow);
      margin-bottom: 1.5rem;
    }
    .panel-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .panel-header h3 {
      font-size: 1rem;
      font-weight: 700;
      color: #cbd5e1;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin: 0;
    }
    .btn-group {
      display: flex;
      background: rgba(15, 23, 42, 0.5);
      padding: 0.2rem;
      border-radius: 8px;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .toggle-btn {
      background: transparent;
      border: none;
      color: #94a3b8;
      padding: 0.3rem 0.7rem;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.72rem;
      font-weight: 700;
      transition: all 0.2s;
