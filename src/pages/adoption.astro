      </div>
      <div class="kpi-card__sparkline" id="sparkline-pulls-almalinux"></div>
    </div>
  </div>

  <div class="dashboard-panel">
    <div class="panel-header">
      <h3>Image Pull Trend</h3>
      <div class="btn-group" id="quay-trend-range-btns">
        <button class="toggle-btn" data-range="30">30d</button>
        <button class="toggle-btn active" data-range="90">90d</button>
      </div>
    </div>
    <div class="chart-box" id="quay-trend"></div>
  </div>

  <!-- Project DORA Health Section -->
  <h2 class="kpi-section-title">Project DORA Health</h2>
  <div class="dora-grid">
    <div class="dora-card">
      <div class="dora-card__name">Bluefin</div>
      <div class="dora-card__level" style="color: #fbbf24;">Medium</div>
      <div class="dora-card__stat">165.1×/wk deploys</div>
      <div class="dora-card__stat">50.3% fail rate</div>
    </div>
    <div class="dora-card">
      <div class="dora-card__name">Aurora</div>
      <div class="dora-card__level" style="color: #fbbf24;">Medium</div>
      <div class="dora-card__stat">9.5×/wk deploys</div>
      <div class="dora-card__stat">17.0% fail rate</div>
    </div>
    <div class="dora-card">
      <div class="dora-card__name">Bazzite</div>
      <div class="dora-card__level" style="color: #fbbf24;">Medium</div>
      <div class="dora-card__stat">6.5×/wk deploys</div>
      <div class="dora-card__stat">27.7% fail rate</div>
    </div>
    <div class="dora-card">
      <div class="dora-card__name">ublue-os</div>
      <div class="dora-card__level" style="color: #fbbf24;">Medium</div>
      <div class="dora-card__stat">17.3×/wk deploys</div>
      <div class="dora-card__stat">20.2% fail rate</div>
    </div>
    <div class="dora-card">
      <div class="dora-card__name">uCore</div>
      <div class="dora-card__level" style="color: #fbbf24;">Medium</div>
      <div class="dora-card__stat">17.3×/wk deploys</div>
      <div class="dora-card__stat">16.7% fail rate</div>
    </div>
    <div class="dora-card">
      <div class="dora-card__name">Zirconium</div>
      <div class="dora-card__level" style="color: #34d399;">High</div>
