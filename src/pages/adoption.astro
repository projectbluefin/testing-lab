  <!-- Future Proofed Section -->
  <h2 class="kpi-section-title">Future Proofed</h2>
  <div class="explainer-box" style="margin-bottom: 1rem;">
    These checks measure OCI image build best practices adopted across the bootc ecosystem.
    Signing and SBOM rates are computed from CI workflow step detection over the last 30 days.
    zstd:chunked, chunking mode, and SLSA provenance are sourced from OCI image supply-chain snapshots.
  </div>
  <div class="fp-table-wrapper">
    <table class="fp-table">
      <thead>
        <tr>
          <th>Image</th>
          <th>Cosign Signing</th>
          <th>SBOM</th>
          <th>zstd:chunked</th>
          <th>chunked (chunka)</th>
          <th>SLSA</th>
        </tr>
      </thead>
      <tbody>
        {dataset.oci_best_practices?.map((item) => {
          const formatStatus = (val: string) => {
            const lower = val.toLowerCase();
            if (lower === 'yes' || lower === 'success' || lower === '✅' || lower === 'true') {
              return <span class="status-badge badge-success">✅ Yes</span>;
            }
            if (lower === 'no' || lower === 'danger' || lower === '❌' || lower === 'false') {
              return <span class="status-badge badge-danger">❌ No</span>;
            }
            if (lower === 'warning' || lower === '⚠️') {
              return <span class="status-badge badge-warning">⚠️</span>;
            }
            return <span class="status-badge badge-muted">{val}</span>;
          };
          return (
            <tr>
              <td class="cell-image">{item.image}</td>
              <td>{formatStatus(item.cosign)}</td>
              <td>{formatStatus(item.sbom)}</td>
              <td>{formatStatus(item.zstd)}</td>
              <td>{formatStatus(item.chunked)}</td>
              <td>{formatStatus(item.slsa)}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
