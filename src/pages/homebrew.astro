---
import SiteLayout from '../layouts/SiteLayout.astro';
import { loadHomebrewPageModel } from '../lib/homebrew-page';
import { serializeJsonScript } from '../lib/json-script';

const baseUrl = import.meta.env.BASE_URL;
const pageModel = loadHomebrewPageModel(`${process.cwd()}/docs/data/homebrew-ecosystem.json`);

const { dataset, summaryMetrics, summaryMetricMap, taps, rows, unavailableRows, chartData } = pageModel;

const serializedPageData = serializeJsonScript(chartData);

const formatUtc = (value: string | null) =>
  value
    ? new Date(value).toLocaleString('en-US', {
        dateStyle: 'medium',
        timeStyle: 'short',
        timeZone: 'UTC',
      }) + ' UTC'
    : 'Never';
---

<SiteLayout
  title="Homebrew"
  description="Homebrew tap and package ecosystem coverage across all tracked Project Bluefin factory image lanes."
  current="homebrew"
>
  <section class="summary-grid" aria-label="Homebrew summary metrics">
    {summaryMetrics.map((metric) => (
      <article class="metric-card">
        <p class="metric-card__label">{metric.label}</p>
        <p class="metric-card__value">{metric.value}</p>
        <p class="metric-card__meta">
          <span>{metric.unit}</span>
          <a href={metric.source_url}>Evidence</a>
        </p>
      </article>
    ))}
  </section>

  <section class="detail-grid detail-grid--hero">
    <article class="status-card status-card--hero">
      <p class="status-card__eyebrow">Homebrew ecosystem coverage</p>
      {unavailableRows.length === rows.length ? (
        <>
          <h2>No Homebrew analytics data is published for any tracked lane</h2>
          <p>
            {rows[0]?.state_reason ?? 'No Homebrew analytics data from formulae.brew.sh or upstream tap repos is tracked in docs/data/ yet.'}
            {' '}All {summaryMetricMap.tracked_image_lanes?.value ?? rows.length} tracked image lanes are
            awaiting Homebrew data.
          </p>
        </>
      ) : unavailableRows.length > 0 ? (
        <>
          <h2>Homebrew data is partially available</h2>
          <p>
            Homebrew analytics data is available for {rows.filter((r) => r.state === 'available').map((r) => `${r.variant}/${r.branch}`).join(', ')}.
            {' '}{unavailableRows.length} lane(s) still await data from formulae.brew.sh or upstream tap repos.
          </p>
        </>
      ) : (
        <>
          <h2>Homebrew data is available for all tracked lanes</h2>
          <p>
            All {rows.length} tracked image lanes have Homebrew analytics data from formulae.brew.sh or
            upstream tap repos. See the per-lane table below for install and download counts.
          </p>
        </>
      )}
      <dl class="status-card__meta">
        <div>
          <dt>Tracked image lanes</dt>
          <dd>{summaryMetricMap.tracked_image_lanes?.value ?? rows.length}</dd>
        </div>
        <div>
          <dt>Lanes with Homebrew data</dt>
          <dd>{summaryMetricMap.lanes_with_brew_data?.value ?? 0}</dd>
        </div>
        <div>
          <dt>Lanes awaiting Homebrew data</dt>
          <dd>{summaryMetricMap.lanes_awaiting_brew_data?.value ?? rows.length}</dd>
        </div>
        <div>
          <dt>Tracked taps</dt>
          <dd>{taps.length > 0 ? taps.map((t) => t.name).join(', ') : 'None tracked yet'}</dd>
        </div>
      </dl>
    </article>

    <article class="status-card">
      <p class="status-card__eyebrow">Availability posture</p>
      <h2>Unavailable states stay visible</h2>
      <ul class="status-list">
        <li>{unavailableRows.length} of {rows.length} lanes lack Homebrew analytics data from formulae.brew.sh or upstream tap repos.</li>
        <li>{taps.length} Homebrew tap(s) explicitly tracked in this dataset.</li>
        <li>
          No Homebrew install or download counts are fabricated.
          Data gaps stay labeled rather than disappearing.
        </li>
      </ul>
      <p class="callout-note">
        This page reads repo-owned migrated Homebrew artifacts committed under <code>docs/data/</code>.
        Bluefin-family lanes reuse the transplanted Brewfile package totals; unmatched lanes remain explicitly unavailable.
      </p>
    </article>
  </section>

  <section class="chart-grid" aria-label="Homebrew charts">
    <article class="status-card chart-card">
      <p class="status-card__eyebrow">Coverage across all tracked image lanes</p>
      <h2>Lane coverage status</h2>
      <p>
        Each bar represents one tracked image lane.
        Height indicates whether Homebrew analytics data is available, partially tracked, or awaiting a
        repo-owned artifact from formulae.brew.sh or upstream tap repos.
      </p>
      <div id="homebrew-lanes-chart" class="chart-surface" role="img" aria-label="Homebrew lane coverage status chart"></div>
    </article>
  </section>

  <section class="detail-grid">
    <article class="status-card">
      <p class="status-card__eyebrow">Per-lane Homebrew details</p>
      <h2>All tracked image lanes</h2>
      <div class="table-scroll">
        <table class="data-table">
          <thead>
            <tr>
              <th scope="col">Variant</th>
              <th scope="col">Branch</th>
              <th scope="col">Tap</th>
              <th scope="col">Installs</th>
              <th scope="col">Downloads</th>
              <th scope="col">Status</th>
              <th scope="col">Evidence</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => (
              <tr>
                <th scope="row">{row.variant}</th>
                <td>{row.branch}</td>
                <td>
                  {row.tap_url ? (
                    <a href={row.tap_url}>{row.tap_name ?? row.tap_url}</a>
                  ) : (
                    <span class="table-note">None tracked</span>
                  )}
                </td>
                <td>
                  {row.install_count !== null ? (
                    row.install_count.toLocaleString()
                  ) : (
                    <span class="table-note">Unavailable</span>
                  )}
                </td>
                <td>
                  {row.download_count !== null ? (
                    row.download_count.toLocaleString()
                  ) : (
                    <span class="table-note">Unavailable</span>
                  )}
                </td>
                <td>
                  <span class:list={['pill', row.state === 'available' ? 'pill--pass' : 'pill--missing']}>
                    {row.state}
                  </span>
                  {row.state !== 'available' && (
                    <p class="table-note">{row.state_reason}</p>
                  )}
                </td>
                <td>
                  <a href={row.source_url}>Source</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </article>

    {taps.length > 0 && (
      <article class="status-card">
        <p class="status-card__eyebrow">Tracked taps</p>
        <h2>Homebrew tap registry</h2>
        <div class="table-scroll">
          <table class="data-table">
            <thead>
              <tr>
                <th scope="col">Tap name</th>
                <th scope="col">URL</th>
                <th scope="col">Status</th>
                <th scope="col">Evidence</th>
              </tr>
            </thead>
            <tbody>
              {taps.map((tap) => (
                <tr>
                  <th scope="row">{tap.name}</th>
                  <td><a href={tap.url}>{tap.url}</a></td>
                  <td>
                    <span class:list={['pill', tap.state === 'available' ? 'pill--pass' : 'pill--missing']}>
                      {tap.state}
                    </span>
                  </td>
                  <td><a href={tap.source_url}>Source</a></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </article>
    )}
  </section>

  <section class="detail-grid">
    <article class="status-card">
      <p class="status-card__eyebrow">Dataset provenance</p>
      <h2>Collector-derived contract</h2>
      <dl class="status-card__meta">
        <div>
          <dt>Schema version</dt>
          <dd>{dataset.schema_version}</dd>
        </div>
        <div>
          <dt>Generated at</dt>
          <dd>{formatUtc(dataset._meta.generated_at)}</dd>
        </div>
        <div>
          <dt>Status</dt>
          <dd>{dataset._meta.status}</dd>
        </div>
      </dl>
      <p class="table-note">{dataset._meta.description}</p>
      <a href={`${baseUrl}data/homebrew-ecosystem.json`}>Open raw dataset</a>
    </article>
  </section>

  <script id="homebrew-page-data" type="application/json" set:html={serializedPageData}></script>
  <script
    is:inline
    src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"
    defer
    data-cfasync="false"
  ></script>
  <script is:inline data-cfasync="false">
    const dataNode = document.getElementById('homebrew-page-data');
    const pageData = dataNode ? JSON.parse(dataNode.textContent || '{}') : null;

    function renderUnavailable(containerId, message) {
      const container = document.getElementById(containerId);
      if (!container) return;
      container.innerHTML = `<div class="chart-empty">${message}</div>`;
    }

    function waitForCharts(attempt) {
      if (attempt === undefined) attempt = 0;
      if (window.echarts) {
        bootCharts(window.echarts);
        return;
      }
      if (attempt > 40) {
        renderUnavailable('homebrew-lanes-chart', 'ECharts failed to load. Table below remains the source of truth.');
        return;
      }
      window.setTimeout(function () { waitForCharts(attempt + 1); }, 125);
    }

    function bootCharts(echarts) {
      if (!pageData) return;

      var lanes = Array.isArray(pageData.laneStatus) ? pageData.laneStatus : [];

      if (lanes.length === 0) {
        renderUnavailable('homebrew-lanes-chart', 'No lane data published in homebrew-ecosystem.json.');
        return;
      }

      var laneContainer = document.getElementById('homebrew-lanes-chart');
      if (!laneContainer) return;

      var hasAnyData = lanes.some(function (l) { return l.stateScore > 0; });

      if (!hasAnyData) {
        renderUnavailable(
          'homebrew-lanes-chart',
          'No Homebrew analytics data is available for any tracked lane yet. ' +
          'Once a repo-owned artifact from formulae.brew.sh or upstream tap repos is committed to docs/data/, ' +
          'this chart will populate automatically.'
        );
        return;
      }

      var chart = echarts.init(laneContainer);
      chart.setOption({
        aria: { enabled: true },
        tooltip: {
          trigger: 'axis',
          axisPointer: { type: 'shadow' },
          formatter: function (params) {
            var lane = lanes[params[0].dataIndex];
            return [
              '<strong>' + lane.label + '</strong>',
              lane.stateLabel,
              lane.installCount !== null ? 'Installs: ' + lane.installCount : 'Installs: unavailable',
              lane.downloadCount !== null ? 'Downloads: ' + lane.downloadCount : 'Downloads: unavailable',
            ].join('<br>');
          },
        },
        grid: { left: 60, right: 20, top: 40, bottom: 80 },
        xAxis: {
          type: 'category',
          data: lanes.map(function (l) { return l.label; }),
          axisLabel: { color: '#cbd5f5', rotate: 30 },
        },
        yAxis: {
          type: 'value',
          max: 2,
          interval: 1,
          axisLabel: {
            color: '#cbd5f5',
            formatter: function (value) {
              if (value === 0) return 'Awaiting';
              if (value === 1) return 'Tracked';
              if (value === 2) return 'Available';
              return '';
            },
          },
        },
        series: [
          {
            name: 'Data coverage',
            type: 'bar',
            data: lanes.map(function (l) { return l.stateScore; }),
            itemStyle: {
              color: function (params) {
                var score = params.data;
                if (score === 2) return '#22c55e';
                if (score === 1) return '#f59e0b';
                return '#334155';
              },
            },
          },
        ],
      });

      window.addEventListener('resize', function () {
        document.querySelectorAll('.chart-surface').forEach(function (element) {
          var instance = echarts.getInstanceByDom(element);
          if (instance) instance.resize();
        });
      });
    }

    waitForCharts();
  </script>
</SiteLayout>
